# coolify.yaml — Generated by claude-skills-deploy init.sh
# Schema reference: https://github.com/Streamlinity/claude-skills-deploy/blob/main/docs/schema.md
#
# SAFE TO COMMIT: this file contains NO secrets. All secrets are
# injected at container start time from Doppler (via DOPPLER_TOKEN env var set by Coolify).
# ─────────────────────────────────────────────────────────────────────
# WHAT YOU NEED TO CHANGE: project, server, doppler_project, registry.image,
#   environments.*.domain, and env_vars.
# LEAVE AS-IS: registry.retention_tags, build defaults (if app is at repo root),
#   environments.*.doppler_environment, coolify_app_ids (auto-filled by /setup-coolify).
# ─────────────────────────────────────────────────────────────────────

# CHANGE: short slug, lowercase, no spaces. Used as the Coolify project name
#         and as the Doppler project name (unless you override doppler_project below).
project: {{PROJECT}}

# CHANGE: must match a key under "servers" in ~/.claude/coolify.json.
#         That file maps this alias to the Coolify URL + API key.
#         Run /setup-coolify init to create ~/.claude/coolify.json if you haven't yet.
server: {{SERVER}}

# CHANGE: Coolify-registered server name where apps are deployed.
#         When absent or commented out (the default), apps deploy on the Coolify host
#         (server_name from coolify.json, defaulting to 'localhost'). Set this only
#         when staging/production apps should run on a separately-registered VPS.
#         If set, also add 'deploy_ssh_host' and (optionally) 'deploy_vps_ip' to the
#         matching server entry in ~/.claude/coolify.json. See docs/schema.md.
{{DEPLOY_SERVER_LINE}}

# CHANGE: Doppler project slug — usually same as project. Leave blank when running
#         init.sh to auto-default to the project name.
doppler_project: {{DOPPLER_PROJECT}}

registry:
  # CHANGE: GHCR image path — org/repo only, NO tag. The CI workflow appends the
  #         git SHA tag automatically. Format: ghcr.io/<github-org>/<repo-name>
  #         init.sh auto-suggests this from your git remote, so you can usually
  #         accept the default.
  image: {{REGISTRY_IMAGE}}
  # LEAVE: how many GHCR image tags to keep. 5 is a safe default.
  retention_tags: 5

# Build paths — LEAVE AS-IS if your Dockerfile is at the repo root (most projects).
# CHANGE context/dockerfile only for monorepos where the app lives in a subdirectory
# (e.g. context: ./myapp, dockerfile: ./myapp/Dockerfile).
build:
  context: {{BUILD_CONTEXT}}
  dockerfile: {{BUILD_DOCKERFILE}}

environments:
  staging:
    # CHANGE: FQDN for staging — no protocol, no trailing slash.
    domain: {{STAGING_DOMAIN}}
    # LEAVE: matches the Doppler config name inside your doppler_project.
    # Doppler creates stg and prd by default — do not change unless you renamed them.
    doppler_environment: stg
  production:
    # CHANGE: FQDN for production — no protocol, no trailing slash.
    domain: {{PROD_DOMAIN}}
    # LEAVE: matches the Doppler config name inside your doppler_project.
    # Doppler creates stg and prd by default — do not change unless you renamed them.
    doppler_environment: prd

# DNS provisioning — optional but recommended.
# When configured, /setup-coolify creates A records pointing at your VPS automatically,
# eliminating the manual DNS step before Let's Encrypt HTTPS issuance succeeds.
# Set provider to 'none' to skip DNS provisioning and create A records manually.
dns:
  # CHANGE: cloudflare | none
  provider: {{DNS_PROVIDER}}
  # CHANGE: root zone (e.g. example.com). Must be a suffix of both staging + production domains.
  # Leave empty when provider is 'none'.
  zone_name: {{DNS_ZONE_NAME}}
  # LEAVE: doppler | coolify_json. Where the API token is stored.
  #   doppler      — token is a secret in your Doppler project (recommended).
  #   coolify_json — token is stored in ~/.claude/coolify.json servers.<alias>.<credential_key>.
  credential_source: {{DNS_CREDENTIAL_SOURCE}}
  # CHANGE: Doppler secret name (e.g. CLOUDFLARE_API_TOKEN) if credential_source=doppler,
  #         OR the coolify.json server field name (e.g. cloudflare_api_token) if credential_source=coolify_json.
  # Leave empty when provider is 'none'.
  credential_key: {{DNS_CREDENTIAL_KEY}}

# Optional: application port exposed by your container (default: 3000).
# CHANGE this when your app listens on a different port — provision.sh uses it for
# health checks and the Coolify port binding. Leave commented out for port 3000 apps.
# port: 3000

# Optional: HTTP path used for health checks (default: /api/health).
# CHANGE this if your app exposes health at a different URL (e.g. /healthz, /health).
# Provision wires Coolify's health-check probe to this path; the CI smoke test also
# curls this path. Leave commented out to keep the default.
# health_check_path: /api/health

# CHANGE: list every environment variable your app reads (e.g. DATABASE_URL).
# These must exist in BOTH the stg and prd Doppler configs.
# They are injected at container start — NOT baked into the image.
# Add all required keys here; /setup-coolify validate will catch missing ones.
env_vars:
{{ENV_VARS_LIST}}

# AUTO-FILLED by /setup-coolify (provision.sh) after first successful run.
# DO NOT edit by hand — the UUIDs are looked up by the skill, not set by you.
# ~ means "not yet provisioned".
coolify_app_ids:
  staging: ~
  production: ~
